# Policy Bot – Environment Variables
# Copy this file to .env and fill in the values after running bootstrap.ps1
# The .env file is auto-generated by bootstrap.ps1; this is the template.

# ── Azure AI Foundry ──────────────────────────────────────────────────────────
# Project endpoint obtained after running bootstrap.ps1
AZURE_AI_PROJECT_ENDPOINT=https://YOUR-HUB.eastus2.api.azureml.ms/api/projects/policybot-project

# Agent ID created by scripts/create-agent.py
POLICYBOT_AGENT_ID=asst_XXXXXXXXXXXXXXXXXXXX

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://search-policybot-SUFFIX.search.windows.net
AZURE_SEARCH_INDEX=ohio-title45-index

# ── Azure OpenAI / AI Services ────────────────────────────────────────────────
# Endpoint of the AI Services resource created by bootstrap.ps1
AZURE_OPENAI_ENDPOINT=https://ais-policybot-SUFFIX.services.ai.azure.com/
# API key (optional – bootstrap.ps1 populates this; omit to use DefaultAzureCredential)
AZURE_OPENAI_API_KEY=
AZURE_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Flask web app ─────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
